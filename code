    function startLangObserver(){
      if(window.__kontaktiLangObserverStarted) return;
      window.__kontaktiLangObserverStarted=true;
      let timer=null;
      const obs=new MutationObserver(()=>{
        if(getLang()!=="en") return;
        clearTimeout(timer);
        timer=setTimeout(()=>translateVisibleText(),20);
      });
      obs.observe(document.body,{childList:true,subtree:true,characterData:true});
    }
    function applyLang(lang){
      // nav-btn title-tekstit päivitetään renderAll:ssa — t() käytetään siellä jo
      // Staattiset tekstit jotka eivät uudelleenpiirry
      const dz=$("#dropzone"); if(dz) dz.innerHTML=t("dropzone")+'<br><span style="opacity:.7">'+t("dropzoneSub")+'</span>';
      document.documentElement.lang=lang;
      // Päivitä lippunappi
      const bl=$("#btnLang");
      if(bl){
        bl.innerHTML=lang==="en"?'<span class="flag-icon gb" aria-hidden="true"></span>':'<span class="flag-icon fi" aria-hidden="true"></span>';
        bl.title="Vaihda kieli / Change language";
        bl.setAttribute("aria-label", lang==="en"?"Change language":"Vaihda kieli");
      }
      const ac=$("#btnAddCustomer"); if(ac) ac.textContent=t("addCustomer");
      renderAll();
    }

    // Kielivalinnan UI
    function showLangOverlay(){
      const ov=$("#langOverlay"); if(ov) ov.removeAttribute("hidden");
    }
    function hideLangOverlay(){
      const ov=$("#langOverlay"); if(ov) ov.setAttribute("hidden","");
    }
    function updateLangDropdown(){
      const lang=getLang();
      document.querySelectorAll(".lang-option").forEach(opt=>{
        opt.classList.toggle("active", opt.dataset.lang===lang);
      });
    }
    function wireLang(){
      // Ensikäynnistys overlay
      $("#langFI")?.addEventListener("click",()=>{setLang("fi");hideLangOverlay()});
      $("#langEN")?.addEventListener("click",()=>{setLang("en");hideLangOverlay()});
      // Maapallo-nappi avaa/sulkee dropdownin
      $("#btnLang")?.addEventListener("click",(e)=>{
        e.stopPropagation();
        const dd=$("#langDropdown");
        if(!dd) return;
        const isHidden=dd.hasAttribute("hidden");
        dd.toggleAttribute("hidden",!isHidden);
        if(isHidden) updateLangDropdown();
      });
      // Kielivalinta dropdownista
      document.querySelectorAll(".lang-option[data-lang]").forEach(btn=>{
        btn.addEventListener("click",(e)=>{
          e.stopPropagation();
          setLang(btn.dataset.lang);
          $("#langDropdown")?.setAttribute("hidden","");
          toast(btn.dataset.lang==="en"?"Language changed":"Kieli vaihdettu");
        });
      });
      // Klikkaus muualle sulkee dropdownin
      document.addEventListener("click",()=>{
        $("#langDropdown")?.setAttribute("hidden","");
      });
    }

    // Splash piilotus
    function hideSplash(){
      const splash=$("#operoSplash"); if(!splash) return;
      // Splash häviää CSS-animaatiolla (3.4s), mutta poistetaan DOM:sta sen jälkeen
      setTimeout(()=>splash.setAttribute("hidden",""), 3500);
      // Oletuskieli on suomi. Ei pakoteta kielivalintaa sovelluksen päälle, jotta napit toimivat heti.
      if(!localStorage.getItem(LS_LANG)){
        localStorage.setItem("kontakti_v1_lang","fi");
      }
    }

    // Yhteinen rajapinta myöhemmälle Kontakti Mobile / PWA -integraatiolle.
    // Mobiili voi lukea saman rakenteen JSON-viennistä tai tästä API:sta, jos se ajetaan samassa WebView/PWA-ympäristössä.
    window.KontaktiIntegration={
      schemaVersion:DATA_SCHEMA_VERSION,
      productFamily:PRODUCT_FAMILY,
      sourceApp:APP_ID,
      getData:()=>normalizeDatasetForSync(activeData()),
      getMobileCallList:()=>normalizeDatasetForSync(activeData()).customers
        .filter(c=>c.mobileVisible!==false && c.nextDate && c.nextDate<=todayISO())
        .sort((a,b)=>((a.priority?0:1)-(b.priority?0:1))||(a.nextDate||"").localeCompare(b.nextDate||"")||(a.name||"").localeCompare(b.name||"")),
      importData:(data)=>{ if(isReadOnly()) return false; state.own=normalizeDatasetForSync(data?.data||data||{}); scheduleSave(); renderAll(); return true; }
    };

    async function init(){
      setTheme(getTheme()); await migrateLegacyIfAny(); state.own=normalizeDatasetForSync(await loadOwn()); state.products=await loadProducts(); wire(); wireQuickSettingsDelegates(); wireLang(); startLangObserver(); renderAll(); runSelfTests();
      // OPERO_SPLASH_START
      hideSplash();
      // OPERO_SPLASH_END
    }
    init();
  })();
  </script>
</body>
</html>
