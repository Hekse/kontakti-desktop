<!doctype html><html lang="fi"><head><meta charset="utf-8"><meta name="viewport" content="width=device-width,initial-scale=1"><title>Kontakti</title><style>html,body{margin:0;min-height:100%;background:#071226;color:#eef4ff;font-family:system-ui,-apple-system,Segoe UI,Roboto,sans-serif;display:grid;place-items:center}.box{max-width:420px;text-align:center;padding:22px}.err{display:none;color:#ffc0c0;white-space:pre-wrap;text-align:left;border:1px solid rgba(239,68,68,.35);background:rgba(239,68,68,.12);border-radius:16px;padding:12px;margin-top:12px}</style></head><body><div class="box"><h2>Avataan Kontakti…</h2><p>Testiversio</p><div id="err" class="err"></div></div><script>(async()=>{try{let html=await fetch('https://raw.githubusercontent.com/Hekse/kontakti-desktop/00ec01642d22cce38966c053615443c12f6e0499/code?cb='+Date.now(),{cache:'no-store'}).then(r=>{if(!r.ok)throw new Error('HTTP '+r.status);return r.text()});document.open();document.write(html);document.close()}catch(e){const el=document.getElementById('err');el.style.display='block';el.textContent='Lataus epäonnistui: '+e.message+'\nPäivitä sivu hetken päästä.'}})();</script></body></html>