<!doctype html>
<html lang="fi">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width,initial-scale=1">
<title>Kontakti</title>
<style>
html,body{margin:0;min-height:100%;background:#071226;color:#eef4ff;font-family:system-ui,-apple-system,Segoe UI,Roboto,sans-serif;display:grid;place-items:center}.box{max-width:420px;text-align:center;padding:22px}.err{display:none;color:#ffc0c0;white-space:pre-wrap;text-align:left;border:1px solid rgba(239,68,68,.35);background:rgba(239,68,68,.12);border-radius:16px;padding:12px;margin-top:12px}
</style>
</head>
<body>
<div class="box"><h2>Avataan Kontakti…</h2><p>Lisätään mobiilituonti.</p><div id="err" class="err"></div></div>
<script>
(async()=>{
  const source='https://raw.githubusercontent.com/Hekse/kontakti-desktop/00ec01642d22cce38966c053615443c12f6e0499/code?cb='+Date.now();
  const patch=`<script>
(function(){
  function findList(){
    try{ if(typeof state!=='undefined' && state.own && Array.isArray(state.own.customers)) return state.own.customers; }catch(e){}
    try{ const d=typeof activeData==='function'?activeData():null; if(d && Array.isArray(d.customers)) return d.customers; }catch(e){}
    return null;
  }
  function val(o,keys,def=''){
    for(const k of keys){ if(o && o[k]!==undefined && o[k]!==null && o[k]!== '') return o[k]; }
    return def;
  }
  function dateVal(v){ if(!v) return ''; const s=String(v); return /^\\d{4}-\\d{2}-\\d{2}/.test(s)?s.slice(0,10):s; }
  function sameNote(a,b){ return String(a.date||'')===String(b.date||'') && String(a.type||'')===String(b.type||'') && String(a.text||'')===String(b.text||''); }
  function normalizeMobile(c){
    const notes=Array.isArray(c.notes)?c.notes:[];
    return {
      id:String(val(c,['id','customer_id','customerId'],'')),
      customer_id:String(val(c,['customer_id','customerId','id'],'')),
      name:String(val(c,['name','customerName','company'],'Nimetön asiakas')),
      city:String(val(c,['city','town'],'')),
      region:String(val(c,['region'],'')),
      business_id:String(val(c,['business_id','businessId','ytunnus'],'')),
      address:String(val(c,['address','street'],'')),
      phone:String(val(c,['phone','tel'],'')),
      email:String(val(c,['email','mail'],'')),
      contact_person:String(val(c,['contact_person','contactPerson'],'')),
      next_date:dateVal(val(c,['next_date','nextDate'],'')),
      next_action:String(val(c,['next_action','nextAction','action'],'')),
      priority:!!val(c,['priority','isPriority'],false),
      meeting:!!val(c,['meeting'],false),
      done:!!val(c,['done','handled'],false),
      incomplete:!!val(c,['incomplete'],false),
      notes:notes.map(n=>({date:dateVal(val(n,['date','createdAt','created_at'],new Date().toISOString())),type:String(val(n,['type','action','kind'],'Merkintä')),text:String(val(n,['text','note','body','content'],''))})).filter(n=>n.text||n.type)
    };
  }
  function findCustomer(list,m){
    return list.find(c=>String(c.id||'')===m.id && m.id) ||
           list.find(c=>String(c.customer_id||c.customerId||'')===m.customer_id && m.customer_id) ||
           list.find(c=>String(c.business_id||c.businessId||'')===m.business_id && m.business_id) ||
           list.find(c=>String(c.name||'').trim().toLowerCase()===m.name.trim().toLowerCase() && m.name);
  }
  function mergeOne(target,m){
    target.id=target.id||m.id||m.customer_id;
    target.customer_id=target.customer_id||target.customerId||m.customer_id||m.id;
    target.customerId=target.customerId||target.customer_id;
    ['name','city','region','address','phone','email'].forEach(k=>{ if(m[k] && !target[k]) target[k]=m[k]; });
    if(m.business_id){ target.business_id=target.business_id||m.business_id; target.businessId=target.businessId||m.business_id; }
    if(m.contact_person){ target.contact_person=target.contact_person||m.contact_person; target.contactPerson=target.contactPerson||m.contact_person; }
    if(m.next_date){ target.next_date=m.next_date; target.nextDate=m.next_date; }
    if(m.next_action){ target.next_action=m.next_action; target.nextAction=m.next_action; }
    target.priority=!!m.priority;
    target.meeting=!!m.meeting || String(m.next_action||'').toLowerCase().includes('tapa');
    target.done=!!m.done;
    target.incomplete=!!m.incomplete;
    if(!Array.isArray(target.notes)) target.notes=[];
    m.notes.forEach(n=>{ if(!target.notes.some(x=>sameNote(x,n))) target.notes.unshift(n); });
    target.updatedAt=new Date().toISOString();
    target.updated_at=target.updatedAt;
  }
  async function importMobileFile(file){
    const text=await file.text();
    const obj=JSON.parse(text);
    const changes=obj.changes || obj.customers || obj.data?.customers;
    if(!Array.isArray(changes)) throw new Error('Tiedostossa ei ole changes- tai customers-listaa');
    const list=findList();
    if(!list) throw new Error('Desktopin asiakaslistaa ei löytynyt');
    let updated=0, added=0;
    changes.map(normalizeMobile).forEach(m=>{
      let c=findCustomer(list,m);
      if(!c){ c={id:m.id||m.customer_id||('mobile_'+Date.now()+'_'+Math.random().toString(36).slice(2)),createdSource:'mobile'}; list.push(c); added++; }
      else updated++;
      mergeOne(c,m);
    });
    try{ if(typeof scheduleSave==='function') scheduleSave(); }catch(e){}
    try{ if(typeof renderAll==='function') renderAll(); else if(typeof render==='function') render(); }catch(e){}
    alert('Mobiilituonti valmis: '+updated+' päivitetty, '+added+' uusi.');
  }
  function addMobileImportButton(){
    if(document.getElementById('mobileChangesInput')) return;
    const input=document.createElement('input'); input.type='file'; input.id='mobileChangesInput'; input.accept='.json,application/json,text/plain'; input.style.display='none';
    input.addEventListener('change',async e=>{ const f=e.target.files&&e.target.files[0]; if(!f) return; try{ await importMobileFile(f); }catch(err){ alert('Mobiilituonti epäonnistui: '+err.message); } input.value=''; });
    document.body.appendChild(input);
    const btn=document.createElement('button'); btn.className='btn primary'; btn.type='button'; btn.textContent='Tuo mobiilista'; btn.onclick=()=>input.click();
    const tools=document.querySelector('.side-tools') || document.querySelector('.topbar') || document.querySelector('.sidebar') || document.body;
    tools.prepend(btn);
  }
  if(document.readyState==='loading') document.addEventListener('DOMContentLoaded',addMobileImportButton); else addMobileImportButton();
})();<\/script>`;
  try{
    let html=await fetch(source,{cache:'no-store'}).then(r=>{if(!r.ok)throw new Error('HTTP '+r.status);return r.text()});
    html=html.replace('</body>',patch+'</body>');
    document.open();document.write(html);document.close();
  }catch(e){const el=document.getElementById('err');el.style.display='block';el.textContent='Lataus epäonnistui: '+e.message+'\nPäivitä sivu hetken päästä.';}
})();
</script>
</body>
</html>