      $("#btnCopyWeekly")?.addEventListener("click",async()=>{const ta=$("#weeklyText");if(!ta) return;ta.select();try{await navigator.clipboard.writeText(ta.value)}catch(e){document.execCommand("copy")}toast(en?"Copied ✓":"Kopioitu ✓")});
      $("#btnRefreshWeekly")?.addEventListener("click",()=>renderWeeklyDetail());
    }
