    function getWeekBounds(offset){const now=new Date();const dayOfWeek=now.getDay()||7;const monday=new Date(now);monday.setDate(now.getDate()-dayOfWeek+1+(offset*7));monday.setHours(0,0,0,0);const sunday=new Date(monday);sunday.setDate(monday.getDate()+6);const thursday=new Date(monday);thursday.setDate(monday.getDate()+3);return {start:localDateISO(monday),end:localDateISO(sunday),weekNum:isoWeekNumber(monday),year:thursday.getFullYear()}}
    function parseSalesFromPurchasesText(text){
      const s=(text||"").toString();
      let sum=0;
      const re=/=\s*([0-9]+(?:[\s.][0-9]{3})*(?:[,.][0-9]{1,2})?|[0-9]+(?:[,.][0-9]{1,2})?)\s*€/g;
      let m;
      while((m=re.exec(s))){sum+=parseNumber(m[1]);}
      return sum;
    }
    function buildWeekly(offset){
      const data=activeData();
      const {start,end,weekNum,year}=getWeekBounds(offset);
      const en=getLang()==="en";
      const yearSales=(data.customers||[]).reduce((sum,c)=>sum+parseNumber(c.salesYTD||0),0);
      let contacts=0,attempts=0,meetings=0,newCustomers=0,sales=0;
      const contactItems=[];
      const attemptItems=[];
      (data.customers||[]).forEach(c=>{
        const notes=(c.notes||[]).slice().sort((a,b)=>(a.createdAt||"").localeCompare(b.createdAt||""));
        const first=notes[0];
        if(first&&first.createdAt>=start&&first.createdAt<=end) newCustomers++;
        notes.forEach(n=>{
          if((n.createdAt||"")>=start&&(n.createdAt||"")<=end){
            const noteText=(n.noteText||"").toLowerCase();
            const isNoAnswer=noteText.includes("ei vastattu") || noteText.includes("no answer");
            if(isNoAnswer) attempts++;
            else contacts++;
            if((n.action||"")==="Tapaaminen") meetings++;
            const noteSales=parseNumber(n.sales||0)||parseSalesFromPurchasesText(n.purchasesText||"");
            sales+=noteSales;
            const item={
              date:n.createdAt||"",customer:c.name||"",city:c.city||"",contact:c.contactPerson||"",phone:c.phone||"",
              action:n.action||"",nextDate:n.nextDate||"",sales:noteSales,note:n.noteText||"",purchases:n.purchasesText||"",isNoAnswer
            };
            if(isNoAnswer) attemptItems.push(item);
            else contactItems.push(item);
          }
        });
      });
      const sortItems=(arr)=>arr.sort((a,b)=>(a.date||"").localeCompare(b.date||"")||(a.customer||"").localeCompare(b.customer||""));
      sortItems(contactItems); sortItems(attemptItems);

      const sameDayLabel=(date,nextDate)=>{
        if(!nextDate) return "";
        if(nextDate===date) return en?"today":"tänään";
        return toFI(nextDate);
      };

      const formatContactItem=(x)=>{
        const action=en?({"Soitto":"Called","Tapaaminen":"Meeting","Tarjous":"Offer","Seuranta":"Follow-up","Sähköposti":"Email","Muu":"Other"}[x.action]||x.action):(x.action||"Kontakti");
        const headline=`${toFI(x.date)} — ${x.customer}${x.city?`, ${x.city}`:""}`;
        const statusParts=[
          action,
          x.nextDate?(en?`next ${sameDayLabel(x.date,x.nextDate)}`:`seuraava ${sameDayLabel(x.date,x.nextDate)}`):"",
          x.sales?`${en?"sales":"myynti"} €${formatMoney(x.sales)}`:""
        ].filter(Boolean).join(" · ");
        const contactLine=[x.contact?`${en?"Contact person":"Yhteyshenkilö"}: ${x.contact}`:"",x.phone?`${en?"Phone":"Puhelin"}: ${x.phone}`:""] .filter(Boolean).join(" · ");
        const noteLine=x.note?`${en?"Note":"Muistiinpano"}: ${x.note}`:"";
        const purchasesLine=x.purchases?`${en?"Purchases":"Ostokset"}:\n${x.purchases}`:"";
        return [headline,statusParts,contactLine,noteLine,purchasesLine].filter(Boolean).join("\n");
      };

      const formatAttemptItem=(x)=>{
        const headline=`${toFI(x.date)} — ${x.customer}${x.city?`, ${x.city}`:""}`;
        const next=sameDayLabel(x.date,x.nextDate);
        const statusLine=en
          ? `No answer${next?` · next attempt ${next}`:""}`
          : `Ei vastattu${next?` · seuraava yritys ${next}`:""}`;
        const contactLine=[x.contact?`${en?"Contact person":"Yhteyshenkilö"}: ${x.contact}`:"",x.phone?`${en?"Phone":"Puhelin"}: ${x.phone}`:""] .filter(Boolean).join(" · ");
        return [headline,statusLine,contactLine].filter(Boolean).join("\n");
      };

      const contactLines=contactItems.map(formatContactItem).join("\n\n");
      const attemptLines=attemptItems.map(formatAttemptItem).join("\n\n");

      const header=en
        ? `Week ${weekNum} / ${year}\n\nContacts: ${contacts}\nNo answer / call attempts: ${attempts}\nMeetings: ${meetings}\nNew customers: ${newCustomers}\nWeek sales: €${formatMoney(sales)}\nCurrent year sales: €${formatMoney(yearSales)}\n\nContacts:\n${contactLines||"–"}\n\nNo answer / call attempts:\n${attemptLines||"–"}`
        : `Viikko ${weekNum} / ${year}\n\nKontaktit: ${contacts}\nEi vastattu / soittoyritykset: ${attempts}\nTapaamiset: ${meetings}\nUudet asiakkaat: ${newCustomers}\nViikon myynti: €${formatMoney(sales)}\nKuluvan vuoden myynti: €${formatMoney(yearSales)}\n\nKontaktit:\n${contactLines||"–"}\n\nEi vastattu / soittoyritykset:\n${attemptLines||"–"}`;
      return {contacts,attempts,meetings,newCustomers,sales,yearSales,reportText:header,weekNum,year,start,end};
    }

