<!doctype html>
<html lang="fi">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <title>Kontakti</title>

  <link rel="icon" type="image/svg+xml" href="data:image/svg+xml;base64," />

  <meta name="theme-color" content="#071226" />
  <meta name="apple-mobile-web-app-capable" content="yes" />
  <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
  <meta name="apple-mobile-web-app-title" content="Kontakti" />
  <link rel="manifest" href='data:application/manifest+json,{"name":"Kontakti","short_name":"Kontakti","start_url":".","display":"standalone","background_color":"#071226","theme_color":"#071226","lang":"fi","orientation":"any","categories":["business","productivity"]}' />

  <style>
    :root{
      --bg0:#071226;
      --bg1:#091a35;
      --panel:rgba(255,255,255,.05);
      --stroke:rgba(255,255,255,.12);
      --text:rgba(255,255,255,.92);
      --muted:rgba(255,255,255,.62);
      --brand:#2d6bff;
      --brand2:#2153c8;
      --ok:#26d07c;
      --warn:#ffcc66;
      --amber:#ff9f43;
      --danger:#ff4d4d;
      --priority:#8b5cf6;
      --shadow:0 14px 40px rgba(0,0,0,.35);
      --shadow2:0 10px 24px rgba(0,0,0,.22);
      --r22:22px;
      --mono:ui-monospace,SFMono-Regular,Menlo,Monaco,Consolas,"Liberation Mono","Courier New",monospace;
      --sans:system-ui,-apple-system,Segoe UI,Roboto,Helvetica,Arial,"Apple Color Emoji","Segoe UI Emoji";
    }
    body.light{
      --bg0:#eef4ff;
      --bg1:#dfe9fb;
      --panel:rgba(255,255,255,.82);
      --stroke:rgba(11,31,68,.12);
      --text:rgba(11,31,68,.94);
      --muted:rgba(11,31,68,.62);
      --shadow:0 14px 40px rgba(11,31,68,.12);
      --shadow2:0 10px 24px rgba(11,31,68,.10);
    }
    *{box-sizing:border-box}
    html,body{height:100%}
    body{margin:0;font-family:var(--sans);color:var(--text);background:radial-gradient(1200px 700px at 18% 0%, rgba(45,107,255,.22), transparent 62%),radial-gradient(1000px 520px at 90% 10%, rgba(38,208,124,.10), transparent 65%),linear-gradient(180deg,var(--bg0),var(--bg1));overflow:hidden}
    .app{height:100%;display:grid;grid-template-columns:260px 1fr;gap:18px;padding:18px;min-height:0}
    .sidebar,.card,.topbar{background:var(--panel);border:1px solid var(--stroke);backdrop-filter:blur(8px)}
    .sidebar{border-radius:var(--r22);box-shadow:var(--shadow);padding:16px 14px;display:flex;flex-direction:column;min-height:0;position:relative}
    .brand{display:flex;flex-direction:column;gap:4px;margin:8px 10px 16px;padding-bottom:12px;border-bottom:1px solid rgba(255,255,255,.08)}
    body.light .brand{border-bottom-color:rgba(11,31,68,.08)}
    .brand .title{font-size:28px;font-weight:760;line-height:1.02}.brand .sub{font-size:12px;font-weight:600;color:var(--muted)}
    .nav{display:flex;flex-direction:column;gap:10px;padding:6px}
    .side-sales{margin:8px 6px 0;padding:12px;border:1px solid rgba(255,255,255,.10);background:rgba(255,255,255,.035);border-radius:16px;display:flex;flex-direction:column;gap:6px}
    body.light .side-sales{border-color:rgba(11,31,68,.10);background:rgba(11,31,68,.035)}
    .side-sales .sales-title{display:flex;align-items:center;gap:8px;font-size:12px;font-weight:720;color:var(--muted);letter-spacing:.01em}
    .side-sales .sales-main{font-size:20px;font-weight:780;line-height:1.05}
    .side-sales .sales-sub{font-size:11px;color:var(--muted);font-weight:620;line-height:1.35}
    .nav-btn{appearance:none;border:1px solid rgba(255,255,255,.10);background:rgba(255,255,255,.035);color:var(--text);border-radius:999px;padding:12px 14px;text-align:left;cursor:pointer;font-weight:650;font-size:22px;display:flex;align-items:center;justify-content:space-between;transition:.15s ease}
    body.light .nav-btn{border-color:rgba(11,31,68,.10);background:rgba(11,31,68,.03)}
    .nav-btn:hover{background:rgba(255,255,255,.055);box-shadow:0 0 0 1px rgba(45,107,255,.10),0 8px 18px rgba(45,107,255,.10)}
    body.light .nav-btn:hover{background:rgba(11,31,68,.05)}
    .nav-btn.active{border-color:rgba(45,107,255,.55);background:rgba(45,107,255,.18);box-shadow:0 0 0 1px rgba(45,107,255,.18),0 0 20px rgba(45,107,255,.26);transform:translateY(-1px)}
    .nav-btn.settings span:first-child{color:#7b8798}
    .pill{font-size:12px;font-weight:640;color:var(--text);background:rgba(255,255,255,.06);border:1px solid rgba(255,255,255,.10);padding:2px 8px;border-radius:999px}
    body.light .pill{background:rgba(11,31,68,.06);border-color:rgba(11,31,68,.10)}
    .pill.mode{border-color:rgba(45,107,255,.45);background:rgba(45,107,255,.14);font-weight:680}.pill.priority{border-color:rgba(139,92,246,.48);background:rgba(139,92,246,.16);font-weight:700}
    .side-tools{margin-top:auto;padding:6px;display:flex;flex-direction:column;gap:10px}
    .btn{appearance:none;border:1px solid rgba(255,255,255,.12);background:rgba(255,255,255,.04);color:var(--text);border-radius:12px;padding:10px 12px;cursor:pointer;font-weight:600;transition:.15s ease;display:inline-flex;align-items:center;justify-content:center;gap:8px;user-select:none}
    body.light .btn{border-color:rgba(11,31,68,.12);background:rgba(11,31,68,.04)}
    .btn:hover{background:rgba(255,255,255,.06)} body.light .btn:hover{background:rgba(11,31,68,.06)} .btn:disabled{opacity:.55;cursor:not-allowed}
    .btn.primary{background:linear-gradient(180deg, rgba(45,107,255,.95), rgba(33,83,200,.95));border-color:rgba(45,107,255,.35);box-shadow:0 10px 18px rgba(45,107,255,.10);color:#fff;font-weight:660}
    .btn.subtle{background:rgba(255,255,255,.03)} body.light .btn.subtle{background:rgba(11,31,68,.03)}
    .btn.priority{border-color:rgba(139,92,246,.48);background:rgba(139,92,246,.10)} .btn.priority.active{background:linear-gradient(180deg, rgba(139,92,246,.95), rgba(109,40,217,.95));border-color:rgba(139,92,246,.55);box-shadow:0 10px 18px rgba(139,92,246,.16);color:#fff}
    .dropzone{border:1px dashed rgba(255,255,255,.22);background:rgba(255,255,255,.03);border-radius:14px;padding:12px;font-size:12px;font-weight:600;color:var(--muted);line-height:1.35;text-align:center;cursor:pointer;transition:.15s ease}
    body.light .dropzone{border-color:rgba(11,31,68,.22);background:rgba(11,31,68,.03)}
    .dropzone:hover{background:rgba(255,255,255,.05)} body.light .dropzone:hover{background:rgba(11,31,68,.05)} .dropzone.dragover{border-color:rgba(45,107,255,.55);background:rgba(45,107,255,.12)}
    .hint{font-size:12px;color:var(--muted);line-height:1.4;font-weight:560}.footer{margin-top:10px;font-size:12px;color:var(--muted);font-weight:560;text-align:center;padding:6px 0 0}
    .main{min-width:0;min-height:0;display:flex;flex-direction:column;gap:14px}
    .topbar{display:flex;align-items:center;justify-content:space-between;gap:12px;border-radius:var(--r22);box-shadow:var(--shadow);padding:12px 14px}
    .topbar .left{display:flex;align-items:center;gap:10px;min-width:0;flex:1}.page-title{font-size:16px;font-weight:700;white-space:nowrap}
    .search{flex:1;min-width:220px;display:flex;gap:10px;align-items:center;background:rgba(255,255,255,.04);border:1px solid rgba(255,255,255,.12);border-radius:999px;padding:10px 12px;max-width:520px}
    body.light .search{background:rgba(11,31,68,.04);border-color:rgba(11,31,68,.12)} .search input{width:100%;border:none;outline:none;background:transparent;color:var(--text);font-weight:560}.search input::placeholder{color:var(--muted)}
    .content{flex:1;min-height:0;display:grid;grid-template-columns:40% 60%;gap:14px}
    .card{border-radius:var(--r22);box-shadow:var(--shadow);min-height:0;display:flex;flex-direction:column;overflow:hidden}
    .card-head{padding:14px 14px 10px;display:flex;align-items:flex-start;justify-content:space-between;gap:10px;border-bottom:1px solid rgba(255,255,255,.08)} body.light .card-head{border-bottom-color:rgba(11,31,68,.08)}
    .card-title{font-size:14px;font-weight:660}.card-sub{font-size:12px;color:var(--muted);font-weight:560;margin-top:3px}.card-body{padding:12px 14px 14px;min-height:0;overflow:auto}
    .list{display:flex;flex-direction:column;gap:10px}.row{border:1px solid rgba(255,255,255,.12);background:rgba(255,255,255,.03);border-radius:14px;padding:12px;cursor:pointer;transition:.14s ease;overflow:hidden}
    body.light .row{border-color:rgba(11,31,68,.12);background:rgba(11,31,68,.03)} .row:hover{background:rgba(255,255,255,.05);transform:translateY(-1px)} body.light .row:hover{background:rgba(11,31,68,.05)}
    .row.active{border-color:rgba(45,107,255,.62);background:rgba(45,107,255,.16);box-shadow:0 0 0 1px rgba(45,107,255,.16),0 14px 30px rgba(0,0,0,.12);transform:translateY(-2px)}
    .row-main{display:flex;align-items:flex-start;justify-content:space-between;gap:12px}.row-left{min-width:0;flex:1;display:flex;gap:10px;align-items:flex-start}.row-right{flex:0 0 auto;display:flex;gap:8px;flex-wrap:wrap;justify-content:flex-end}
    .row-name{font-weight:680;line-height:1.2}.row-meta{font-size:12px;color:var(--muted);font-weight:560;margin-top:6px;line-height:1.35}
    .status-dot{width:12px;height:12px;border-radius:50%;flex:0 0 12px;margin-top:4px;border:1px solid rgba(255,255,255,.22);box-shadow:0 0 0 3px rgba(255,255,255,.03)}
    body.light .status-dot{border-color:rgba(11,31,68,.18);box-shadow:0 0 0 3px rgba(11,31,68,.03)} .status-dot.green{background:var(--ok)} .status-dot.yellow{background:var(--warn)} .status-dot.orange{background:var(--amber)} .status-dot.red{background:var(--danger)} .status-dot.gray{background:rgba(255,255,255,.28)} body.light .status-dot.gray{background:rgba(11,31,68,.28)}
    .tagline{display:flex;gap:8px;align-items:center;flex-wrap:wrap;margin-top:10px}.tag{font-size:12px;font-weight:560;color:var(--text);background:rgba(255,255,255,.06);border:1px solid rgba(255,255,255,.10);padding:2px 8px;border-radius:999px}
    body.light .tag{background:rgba(11,31,68,.06);border-color:rgba(11,31,68,.10)} .tag.ok{border-color:rgba(38,208,124,.30);background:rgba(38,208,124,.09)} .tag.bad{border-color:rgba(255,77,77,.30);background:rgba(255,77,77,.09)} .tag.priority{border-color:rgba(139,92,246,.48);background:rgba(139,92,246,.12);font-weight:680}
    .detail{display:grid;grid-template-rows:auto 1fr;min-height:0}.detail-header{padding:14px 14px 10px;border-bottom:1px solid rgba(255,255,255,.08);display:flex;align-items:flex-start;justify-content:space-between;gap:10px} body.light .detail-header{border-bottom-color:rgba(11,31,68,.08)}
    .detail-header h2{margin:0;font-size:24px;font-weight:760;line-height:1.1}.detail-header .subline{margin-top:8px;font-size:12px;font-weight:560;color:var(--muted);display:flex;gap:10px;flex-wrap:wrap}
    .detail-body{padding:12px 14px 14px;overflow:auto;min-height:0;display:flex;flex-direction:column;gap:14px}
    .note-box{border:1px solid rgba(255,255,255,.12);background:rgba(255,255,255,.03);border-radius:16px;padding:12px;display:flex;flex-direction:column;gap:10px;box-shadow:var(--shadow2)} body.light .note-box{border-color:rgba(11,31,68,.12);background:rgba(11,31,68,.03)}
    .note-top{display:flex;align-items:center;justify-content:space-between;gap:10px}.note-top .t{font-weight:620}.note-top .d{font-family:var(--mono);font-size:12px;color:var(--muted);font-weight:560}
    .field{display:flex;flex-direction:column;gap:8px}.label{font-size:12px;color:var(--muted);font-weight:560}
    input,textarea,select{width:100%;background:rgba(255,255,255,.05);border:1px solid rgba(255,255,255,.12);color:var(--text);border-radius:14px;padding:10px 12px;outline:none;font-weight:560;font-family:inherit}
    body.light input,body.light textarea,body.light select{background:rgba(11,31,68,.05);border-color:rgba(11,31,68,.12)} textarea{min-height:120px;resize:vertical} input::placeholder,textarea::placeholder{color:var(--muted)} select option{background:#0d1a33;color:#fff} body.light select option{background:#fff;color:#0d1a33}
    .grid2{display:grid;grid-template-columns:1fr 1fr;gap:12px}.actions{display:flex;gap:10px;flex-wrap:wrap}.switchline{display:flex;align-items:center;justify-content:space-between;gap:12px;border:1px solid rgba(255,255,255,.10);background:rgba(255,255,255,.03);border-radius:14px;padding:10px 12px} body.light .switchline{border-color:rgba(11,31,68,.10);background:rgba(11,31,68,.03)}
    .kvlist{display:flex;flex-direction:column;gap:8px}.kvrow{display:flex;gap:10px;align-items:flex-start;justify-content:space-between;border:1px solid rgba(255,255,255,.12);background:rgba(255,255,255,.03);border-radius:12px;padding:10px} body.light .kvrow{border-color:rgba(11,31,68,.12);background:rgba(11,31,68,.03)} .kvrow b{font-weight:620}.kvrow span,.kvrow a{color:var(--text);font-weight:580;text-decoration:none;word-break:break-word;text-align:right;max-width:65%}.kvrow a:hover{text-decoration:underline}
    .quick,.inline-actions{display:flex;gap:10px;flex-wrap:wrap}
    .history-popover{position:fixed;right:24px;bottom:24px;width:min(460px, calc(100vw - 32px));max-height:min(72vh,760px);z-index:120;border:1px solid rgba(255,255,255,.12);background:rgba(7,18,38,.96);backdrop-filter:blur(14px);border-radius:18px;box-shadow:0 24px 60px rgba(0,0,0,.38);display:flex;flex-direction:column;overflow:hidden}
    body.light .history-popover{background:rgba(255,255,255,.96);border-color:rgba(11,31,68,.12);box-shadow:0 24px 60px rgba(11,31,68,.18)} .history-popover[hidden]{display:none}
    .history-head{display:flex;align-items:center;justify-content:space-between;gap:12px;padding:14px 16px 12px;border-bottom:1px solid rgba(255,255,255,.08)} body.light .history-head{border-bottom-color:rgba(11,31,68,.08)} .history-title{font-size:15px;font-weight:700}.history-sub{font-size:12px;color:var(--muted);font-weight:560;margin-top:3px}.history-body{padding:12px 14px 14px;overflow:auto;display:flex;flex-direction:column;gap:10px}
    .history-item{border:1px solid rgba(255,255,255,.10);background:rgba(255,255,255,.03);border-radius:14px;padding:12px;display:flex;flex-direction:column;gap:8px} body.light .history-item{border-color:rgba(11,31,68,.10);background:rgba(11,31,68,.03)} .history-meta{display:flex;gap:8px;align-items:center;justify-content:space-between;flex-wrap:wrap}.history-date{font-family:var(--mono);font-size:12px;color:var(--muted);font-weight:560}.history-badges{display:flex;gap:8px;flex-wrap:wrap}.history-text{white-space:pre-wrap;line-height:1.45;font-size:13px}
    .saveflash.is-ok{background:rgba(38,208,124,.16)!important;border-color:rgba(38,208,124,.35)!important;box-shadow:0 0 0 1px rgba(38,208,124,.12),0 12px 26px rgba(38,208,124,.08)}
    .settings-grid{display:grid;grid-template-columns:1fr;gap:14px}.settings-row{display:flex;gap:10px;flex-wrap:wrap}.legend-grid{display:grid;grid-template-columns:1fr;gap:8px}.legend-row{display:flex;align-items:center;gap:10px;border:1px solid rgba(255,255,255,.10);background:rgba(255,255,255,.03);border-radius:12px;padding:10px 12px} body.light .legend-row{border-color:rgba(11,31,68,.10);background:rgba(11,31,68,.03)} .legend-icon{width:22px;text-align:center;font-size:16px}
    .filter-dots{display:flex;gap:8px;align-items:center;margin-top:8px}.filter-dot{width:16px;height:16px;border-radius:50%;border:1px solid rgba(255,255,255,.24);cursor:pointer;box-shadow:0 0 0 2px rgba(255,255,255,.03);transition:.15s ease} body.light .filter-dot{border-color:rgba(11,31,68,.18);box-shadow:0 0 0 2px rgba(11,31,68,.03)} .filter-dot:hover{transform:scale(1.08)} .filter-dot.active{box-shadow:0 0 0 2px rgba(255,255,255,.08),0 0 12px currentColor} .filter-dot.green{background:var(--ok);color:var(--ok)} .filter-dot.yellow{background:var(--warn);color:var(--warn)} .filter-dot.orange{background:var(--amber);color:var(--amber)} .filter-dot.red{background:var(--danger);color:var(--danger)} .list-arrows{display:flex;gap:6px}.list-arrows .btn{min-width:42px;padding-inline:0}
    @media (max-width:980px){body{overflow:auto}.app{grid-template-columns:1fr;overflow:auto}.content{grid-template-columns:1fr}}
    @media (max-width:680px){.content{position:relative}.card.detail{position:fixed;inset:12px;z-index:50;display:none}.card.detail.show{display:flex}.mobile-back{display:inline-flex!important}.grid2{grid-template-columns:1fr}.row-main{flex-direction:column}.row-right{justify-content:flex-start}.history-popover{left:12px;right:12px;bottom:12px;width:auto;max-height:68vh}}
    .mobile-back{display:none}

    /* ── OPERO LOGO MARK ───────────────────────────────────── */
    .opero-logo-mark{position:relative;display:grid;place-items:center;border-radius:50%;isolation:isolate;color:#eaf7ff;background:radial-gradient(circle at 30% 18%,rgba(255,255,255,.52),rgba(255,255,255,.08) 28%,transparent 46%),conic-gradient(from 225deg,#052a96,#166cff,#5adfff,#146dff,#052a96);box-shadow:0 0 0 1px rgba(150,220,255,.22) inset,0 0 28px rgba(42,136,255,.36),0 18px 34px rgba(0,0,0,.35)}
    .opero-logo-mark::before{content:"";position:absolute;inset:20%;border-radius:50%;background:radial-gradient(circle at 36% 24%,rgba(45,107,255,.16),transparent 42%),linear-gradient(180deg,#071b3a,#030b1c);box-shadow:0 0 0 1px rgba(180,230,255,.14) inset,0 10px 22px rgba(0,0,0,.32) inset;z-index:0}
    .opero-logo-mark .opero-euro{position:relative;z-index:1;font-family:Arial,Helvetica,sans-serif;font-weight:900;line-height:1;letter-spacing:-.09em;transform:translateX(4%);background:linear-gradient(145deg,#7fecff 0%,#1e8bff 42%,#0646d8 100%);-webkit-background-clip:text;background-clip:text;color:transparent;text-shadow:0 2px 0 rgba(255,255,255,.18),0 0 18px rgba(66,170,255,.38);filter:drop-shadow(0 8px 10px rgba(0,0,0,.30))}
    .opero-logo-mini{width:42px;height:42px;flex:0 0 42px}
    .opero-logo-mini .opero-euro{font-size:29px}
    .brand-name{display:flex;align-items:center;gap:11px;min-width:0}

    /* ── OPERO SPLASH ─────────────────────────────────────── */
    .opero-splash{position:fixed;inset:0;z-index:200;display:flex;align-items:center;justify-content:center;background:radial-gradient(circle at center,rgba(30,100,255,.10),transparent 28%),linear-gradient(180deg,#03122c 0%,#020b1c 100%);animation:splashFade 3.4s ease forwards;pointer-events:none}
    .opero-splash[hidden]{display:none}
    .splash-shell{position:relative;display:flex;flex-direction:column;align-items:center;gap:18px;opacity:0;transform:translateY(6px) scale(.985);animation:splashRise 1.2s ease .15s forwards}
    .splash-brand{display:flex;align-items:center;gap:10px;z-index:2}
    .splash-logo{width:104px;height:104px;flex:0 0 104px}
    .splash-logo .opero-euro{font-size:72px}
    .splash-opero{font-size:76px;font-weight:850;letter-spacing:.055em;color:#fff;line-height:1;text-shadow:0 10px 24px rgba(0,0,0,.42),0 0 26px rgba(70,150,255,.18)}
    @media (max-width:680px){.splash-brand{gap:8px}.splash-logo{width:82px;height:82px;flex-basis:82px}.splash-logo .opero-euro{font-size:56px}.splash-opero{font-size:54px}}
    .splash-line{width:180px;height:3px;border-radius:999px;background:linear-gradient(90deg,transparent,#39a0ff,transparent);box-shadow:0 0 14px rgba(57,160,255,.45);z-index:2}
    .splash-product{font-size:28px;font-weight:700;letter-spacing:.22em;color:#fff;z-index:2}
    .splash-line-bottom{margin-top:110px;z-index:2}
    .splash-loading{font-size:15px;color:rgba(236,242,255,.90);z-index:2}
    @keyframes splashRise{to{opacity:1;transform:translateY(0) scale(1)}}
    @keyframes splashFade{0%,70%{opacity:1;visibility:visible}100%{opacity:0;visibility:hidden}}

    /* ── KIELIVALINTA (ensimmäinen käynnistys) ────────────────*/
    .lang-overlay{position:fixed;inset:0;z-index:190;display:flex;align-items:center;justify-content:center;background:rgba(3,10,24,.72);backdrop-filter:blur(10px)}
    .lang-overlay[hidden]{display:none}
    .lang-card{background:var(--panel);border:1px solid var(--stroke);border-radius:var(--r22);padding:28px 24px;box-shadow:var(--shadow);display:flex;flex-direction:column;align-items:center;gap:18px;min-width:260px}
    .lang-title{font-size:18px;font-weight:700}
    .lang-sub{font-size:12px;color:var(--muted);text-align:center;line-height:1.5}
    .lang-btns{display:flex;gap:12px}
    .lang-btn{appearance:none;border:1px solid var(--stroke);background:rgba(255,255,255,.04);color:var(--text);border-radius:14px;width:72px;height:58px;font-size:30px;font-weight:700;cursor:pointer;transition:.15s ease;display:grid;place-items:center}
    .lang-btn:hover{background:rgba(45,107,255,.18);border-color:rgba(45,107,255,.55)}
